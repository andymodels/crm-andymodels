# Em desenvolvimento local o projeto na raiz usa PORT=3030 (evita conflito com Replit na 3001).
PORT=3030
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/andy_models

# Contrato (texto padrão + dados da O.S.) e envio por e-mail
AGENCIA_RAZAO_SOCIAL=Andy Models — Agência de Modelos
AGENCIA_CNPJ=
AGENCIA_ENDERECO=
AGENCIA_EMAIL=
CONTRATO_EMAIL_ASSUNTO=Contrato — O.S.

# URL pública do CRM (contratos, redirects /crm, uploads locais em /uploads/..., etc.). Opcional: se vazio, usa o host Render padrão do projeto.
# O front estático do andymodels.com (AndyRadio) deve pedir GET {PUBLIC_APP_URL}/api/public/radio/v2 — não há outro backend no domínio do site.
# PUBLIC_APP_URL=https://crm-andymodels.onrender.com

# Rádio: na primeira subida do servidor após este deploy, remove playlists de teste (nome com «teste», slug test-* ou demo-*). Para não executar: RADIO_SKIP_PURGE_TEST_ON_BOOT=1
# RADIO_SKIP_PURGE_TEST_ON_BOOT=1

# Obrigatório para guardar modelos no site (Website → Modelos): proxy CRM repassa PUT/POST/PATCH a …/api/admin/models… com Authorization: Bearer <token>.
# Log de cada pedido /api no stdout (1 = ligado): DEBUG_CRM_ROUTES=1
# No site (adminAuth): o token é config.adminSecret — login POST /api/admin/auth/login com { password } (ADMIN_PASSWORD) devolve { token } = ADMIN_SECRET.
# No CRM pode usar qualquer um destes nomes com o MESMO valor que ADMIN_SECRET no site:
# ADMIN_SECRET=
# WEBSITE_ADMIN_API_KEY=
# WEBSITE_ADMIN_TOKEN=

# Origem da API pública + admin do site institucional (predefinição: https://www.andymodels.com). Só altere se o site estiver noutro domínio.
# WEBSITE_ORIGIN=https://www.andymodels.com

# Diagnóstico: logs no stdout (Render → Logs) com URL, método, body e resposta — Authorization e segredo NUNCA em claro. Desligar após resolver (1 = ligado).
# DEBUG_WEBSITE_PROXY=1

# Armazenamento de ficheiros: local (uploads/) ou b2 (S3-compatible, ex. Backblaze B2)
# STORAGE_DRIVER=local
# STORAGE_DRIVER=b2
# B2_S3_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
# B2_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET=
# URL pública (Friendly URL do bucket, sem barra final) — OBRIGATÓRIO com STORAGE_DRIVER=b2 para gravar URL na BD:
# B2_PUBLIC_BASE_URL=https://f005.backblazeb2.com/file/nome-do-bucket
# Alternativa: host "fXXX..." + bucket (monta o mesmo prefixo)
# B2_DOWNLOAD_HOST=f005.backblazeb2.com

# Links gerados em Cadastros → “Gerar link” (modelo/cliente). Não usa PUBLIC_APP_URL.
# CADASTRO_PUBLIC_URL=https://crm-andymodels.onrender.com

# SMTP (opcional — sem isso, o envio por e-mail retorna 503)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remetente: pode omitir se SMTP_USER for um e-mail válido
MAIL_FROM=

# Convocação da Agenda: só estes links no e-mail (não usa PUBLIC_APP_URL — evita apontar para o site institucional)
# AGENDA_EMAIL_PUBLIC_URL=https://crm-andymodels.onrender.com

# Ordem de envio da convocação (só a agenda): 1) AGENDA_SMTP_*  2) BREVO_API_KEY (API com tracking off)  3) SMTP global
#
# 1) Opcional — SMTP só para convocação (ex.: Amazon SES, Mailgun), sem reescrita Brevo/sendibt:
# AGENDA_SMTP_HOST=
# AGENDA_SMTP_PORT=587
# AGENDA_SMTP_SECURE=false
# AGENDA_SMTP_USER=
# AGENDA_SMTP_PASS=
# AGENDA_MAIL_FROM=
# Se o dedicado falhar, por defeito tenta Brevo/SMTP global. Para falhar logo: AGENDA_SMTP_FAIL_CLOSED=true
#
# 2) Brevo API v3 — payload inclui tracking: { clicks: false, opens: false } + headers X-Sib-Options
# MAIL_FROM (ou SMTP_USER) = remetente verificado no Brevo
# BREVO_API_KEY=xkeysib-...
