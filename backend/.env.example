# Em desenvolvimento local o projeto na raiz usa PORT=3030 (evita conflito com Replit na 3001).
PORT=3030
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/andy_models

# Contrato (texto padrão + dados da O.S.) e envio por e-mail
AGENCIA_RAZAO_SOCIAL=Andy Models — Agência de Modelos
AGENCIA_CNPJ=
AGENCIA_ENDERECO=
AGENCIA_EMAIL=
CONTRATO_EMAIL_ASSUNTO=Contrato — O.S.

# URL pública do CRM (links no e-mail). Opcional: se vazio, usa o host Render padrão do projeto.
# PUBLIC_APP_URL=https://crm-andymodels.onrender.com

# SMTP (opcional — sem isso, o envio por e-mail retorna 503)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Remetente: pode omitir se SMTP_USER for um e-mail válido
MAIL_FROM=

# Convocação da Agenda: links no e-mail (por defeito = PUBLIC_APP_URL ou https://crm-andymodels.onrender.com)
# AGENDA_EMAIL_PUBLIC_URL=https://crm-andymodels.onrender.com

# Ordem de envio da convocação (só a agenda): 1) AGENDA_SMTP_*  2) BREVO_API_KEY (API com tracking off)  3) SMTP global
#
# 1) Opcional — SMTP só para convocação (ex.: Amazon SES, Mailgun), sem reescrita Brevo/sendibt:
# AGENDA_SMTP_HOST=
# AGENDA_SMTP_PORT=587
# AGENDA_SMTP_SECURE=false
# AGENDA_SMTP_USER=
# AGENDA_SMTP_PASS=
# AGENDA_MAIL_FROM=
# Se o dedicado falhar, por defeito tenta Brevo/SMTP global. Para falhar logo: AGENDA_SMTP_FAIL_CLOSED=true
#
# 2) Brevo API v3 — payload inclui tracking: { clicks: false, opens: false } + headers X-Sib-Options
# MAIL_FROM (ou SMTP_USER) = remetente verificado no Brevo
# BREVO_API_KEY=xkeysib-...
