# O proxy do Vite encaminha /api para 127.0.0.1:PORT. Se definir VITE_API_URL=http://localhost:3001, use a mesma porta que o backend (ou deixe VITE_API_URL vazio e VITE_DEV_PROXY_PORT=3030).
VITE_DEV_PROXY_PORT=3030
VITE_API_URL=
# Origem pública do site (miniaturas com URLs relativas no CRM). Predefinição: https://www.andymodels.com
# VITE_WEBSITE_ORIGIN=https://www.andymodels.com
# Segmento do URL do perfil do modelo no site (links na UI + pré-visualização). Predefinição: modelo → …/modelo/slug
# No servidor (Render), opcional: WEBSITE_MODEL_PUBLIC_PATH=modelo — alinha com o segmento real do site.
# VITE_WEBSITE_MODEL_PATH=modelo
